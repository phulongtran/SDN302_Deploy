<!DOCTYPE html>
<html>
<head>
    <title>Room Bookings</title>

    <style>
        body{
            background:#eef2f7;
            font-family:Arial;
        }

        h1{
            text-align:center;
            color:#1f6feb;
        }

        table{
            width:90%;
            margin:auto;
            border-collapse:collapse;
            background:white;
        }

        th{
            background:#1f6feb;
            color:white;
            padding:10px;
        }

        td{
            padding:10px;
            text-align:center;
            border:1px solid #ddd;
        }

.update{
    background:#1f6feb;
    color:white;
    padding:5px 12px;
    text-decoration:none;
    border-radius:4px;
    margin-right:8px;
    display:inline-block;
}

.delete{
    background:#f39c12;
    color:white;
    padding:5px 12px;
    text-decoration:none;
    border-radius:4px;
    display:inline-block;
}

        .book-btn{
            display:block;
            width:120px;
            margin:20px auto;
            background:#1f6feb;
            color:white;
            text-align:center;
            padding:10px;
            border-radius:5px;
            text-decoration:none;
        }
        .action-buttons{
    display:flex;
    justify-content:center;
    gap:10px;
}
    </style>
</head>

<body>

<h1>Room Bookings</h1>

<table>
    <tr>
        <th>Customer Name</th>
        <th>Room Number</th>
        <th>Start Time</th>
        <th>End Time</th>
        <th>Total Amount</th>
        <th>Actions</th>
    </tr>

    <% bookings.forEach(booking=>{ %>

    <tr>
        <td><%= booking.customerName %></td>
        <td><%= booking.roomNumber %></td>
        <td><%= booking.startTime %></td>
        <td><%= booking.endTime %></td>
        <td><%= booking.totalAmount %> VND</td>

<td class="action-buttons">
    <a class="update"
       href="/bookings/edit/<%= booking._id %>">
       Update
    </a>

    <a class="delete"
       href="/bookings/delete/<%= booking._id %>">
       Delete
    </a>
</td>
    </tr>

    <% }) %>

</table>

<a href="/bookings/add" class="book-btn">
    Book a Room
</a>

</body>
</html>